### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# Your preferred terminal emulator
set $term alacritty
# Your preferred application launcher
#set $menu env QT_QPA_PLATFORM=wayland QT_SCALE_FACTOR=1 QT_AUTO_SCREEN_SCALE_FACTOR=0 wofi --show drun | xargs swaymsg exec --
set $menu env QT_QPA_PLATFORM=wayland wofi --show drun | xargs swaymsg exec --

include ~/.config/sway/keybinds.conf
include ~/.config/sway/theme.conf


### Output configuration
#
#output * bg /home/zphish/Pictures/wallpapers/vector-wallpaper.png fill
output * bg /home/zphish/Pictures/wallpapers/Kath.png fill
bindsym $mod+w exec ~/.config/sway/changeWallpaper.sh


